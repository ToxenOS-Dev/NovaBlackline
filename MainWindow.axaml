<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NovaBlackline.MainWindow"
        WindowState="FullScreen"
        Background="Black"
        Icon="avares://NovaBlackline/Assets/icon.png">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFD700"/>
        <SolidColorBrush x:Key="AccentLineBrush" Color="#55FFD700"/>
        <SolidColorBrush x:Key="AccentButtonBackgroundBrush" Color="#1AFFD700"/>
        <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="#44FFD700"/>
        <SolidColorBrush x:Key="AccentShopBorderBrush" Color="#33FFD700"/>
        <SolidColorBrush x:Key="AccentDividerBrush" Color="#22FFD700"/>
        <SolidColorBrush x:Key="AccentSettingsBorderBrush" Color="#55FFD700"/>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#000000"/>
        <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#DD000000"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#0F0F0F"/>
    </Window.Resources>

    <Grid>

        <!-- Layer 1: App wallpaper -->
        <Image x:Name="WallpaperImage"
               Stretch="UniformToFill"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"/>

        <!-- Layer 2: Vignette / color overlay -->
        <Border x:Name="DimOverlay"/>

        <!-- Layer 3: Bottom dark scrim (always on, over everything below) -->
        <Border VerticalAlignment="Bottom" Height="320">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#BB000000" Offset="0.55"/>
                    <GradientStop Color="#FF000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Layer 4: UI -->
        <Grid RowDefinitions="80,*,160">

            <!-- Top bar -->
            <Grid Grid.Row="0">

                <!-- Bar background: opaque dark on left, fades right -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                            <GradientStop Color="#CC000000" Offset="0"/>
                            <GradientStop Color="#55000000" Offset="0.5"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Accent line along the bottom of the bar -->
                <Rectangle Height="1" VerticalAlignment="Bottom" Fill="{DynamicResource AccentLineBrush}"/>

                <!-- Bar content -->
                <Grid Margin="50,0">

                    <!-- Left: accent pip + title -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Spacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Rectangle Width="4" Height="18" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                            <Rectangle Width="4" Height="22" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                            <Rectangle Width="4" Height="26" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TopTitleText"
                                   Text="NOVA BLACKLINE"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Center: clock -->
                    <TextBlock x:Name="ClockText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Right: store + settings + hamburger -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="12">

                        <!-- Store button -->
                        <Border x:Name="StoreButton"
                                Background="{DynamicResource AccentButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource AccentButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,6"
                                Cursor="Hand">
                            <TextBlock x:Name="StoreText"
                                       Text="STORE"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Library button -->
                        <Border x:Name="LibraryButton"
                                Background="{DynamicResource AccentButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource AccentButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,6"
                                Cursor="Hand">
                            <TextBlock Text="LIBRARY"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Settings button -->
                        <Border x:Name="SettingsButton"
                                Background="{DynamicResource AccentButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource AccentButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,6"
                                Cursor="Hand">
                            <TextBlock Text="⚙"
                                       FontSize="14"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Hamburger menu -->
                        <Border x:Name="MenuButton"
                                Background="{DynamicResource AccentButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource AccentButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="11,9"
                                Cursor="Hand">
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <Rectangle Width="18" Height="2" Fill="{DynamicResource AccentBrush}"/>
                                <Rectangle Width="18" Height="2" Fill="{DynamicResource AccentBrush}"/>
                                <Rectangle Width="18" Height="2" Fill="{DynamicResource AccentBrush}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Tile canvas -->
            <Canvas x:Name="TilesCanvas" Grid.Row="1" ClipToBounds="True"/>

            <!-- Bottom info -->
            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10">
                <TextBlock x:Name="ItemNameText"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock x:Name="ItemDescText"
                           FontSize="14"
                           Foreground="White"
                           Opacity="0.45"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock x:Name="BottomHintText"
                           Text="←  →   navigate        ENTER   launch        ESC   quit"
                           FontSize="11"
                           Foreground="White"
                           Opacity="0.22"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,0"/>
            </StackPanel>

        </Grid>

        <!-- Layer 5: Shop overlay -->
        <Grid x:Name="ShopOverlay" IsVisible="False">
            <Border Background="{DynamicResource OverlayBackgroundBrush}"/>
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentShopBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Width="900"
                    Height="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="64,1,*,1,46">

                    <!-- Tab bar -->
                    <StackPanel x:Name="ShopTabBar"
                                Grid.Row="0"
                                Orientation="Horizontal"
                                Spacing="0"
                                VerticalAlignment="Stretch"
                                Margin="8,0"/>

                    <Rectangle Grid.Row="1" Fill="{DynamicResource AccentDividerBrush}"/>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="2">
                        <StackPanel x:Name="ShopContent" Margin="30,24,30,0"/>
                    </ScrollViewer>

                    <Rectangle Grid.Row="3" Fill="{DynamicResource AccentDividerBrush}"/>

                    <!-- Footer hint (updated in code based on focus level) -->
                    <TextBlock x:Name="ShopFooterHint"
                               Grid.Row="4"
                               FontSize="11"
                               Foreground="White"
                               Opacity="0.25"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Layer 6: Library overlay -->
        <Grid x:Name="LibraryOverlay" IsVisible="False">
            <Border Background="{DynamicResource OverlayBackgroundBrush}"/>
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentShopBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Width="700"
                    Height="540"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="64,1,*,1,46">

                    <!-- Title bar -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center"
                                Margin="28,0">
                        <TextBlock Text="STEAM LIBRARY"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="LibrarySubtitle"
                                   FontSize="12"
                                   Foreground="White"
                                   Opacity="0.4"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Grid.Row="1" Fill="{DynamicResource AccentDividerBrush}"/>

                    <!-- Game list -->
                    <ScrollViewer x:Name="LibraryScrollViewer" Grid.Row="2">
                        <StackPanel x:Name="LibraryContent" Margin="24,20,24,8"/>
                    </ScrollViewer>

                    <Rectangle Grid.Row="3" Fill="{DynamicResource AccentDividerBrush}"/>

                    <!-- Footer hint -->
                    <TextBlock x:Name="LibraryFooterHint"
                               Grid.Row="4"
                               Text="↑ ↓  navigate        ENTER  install        ESC  close"
                               FontSize="11"
                               Foreground="White"
                               Opacity="0.25"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Layer 8: Settings overlay — must be last so it renders on top of everything -->
        <Grid x:Name="SettingsOverlay" IsVisible="False">
            <Border Background="{DynamicResource OverlayBackgroundBrush}"/>
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentSettingsBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Width="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="48,40">
                <StackPanel>
                    <TextBlock x:Name="SettingsTitleText"
                               Text="SETTINGS"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,28"/>
                    <StackPanel x:Name="SettingsRows" Spacing="4"/>
                    <TextBlock x:Name="SettingsHintText"
                               Text="↑ ↓  select        ← →  change        ESC  close"
                               FontSize="11"
                               Foreground="White"
                               Opacity="0.25"
                               HorizontalAlignment="Center"
                               Margin="0,28,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Layer 9: Right sidebar menu -->
        <Grid x:Name="MenuOverlay" IsVisible="False">

            <!-- Dim background — clicking it closes the menu -->
            <Border x:Name="MenuDimBackground" Background="#55000000"/>

            <!-- Sidebar panel -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentSettingsBorderBrush}"
                    BorderThickness="1,0,0,0"
                    HorizontalAlignment="Right"
                    Width="280">
                <StackPanel Margin="32,40,32,32" Spacing="20">

                    <TextBlock Text="MENU"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>

                    <Rectangle Height="1" Fill="{DynamicResource AccentLineBrush}"/>

                    <Border x:Name="CloseAppButton"
                            Background="#AA1A1A1A"
                            BorderBrush="#BB331111"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="0,14"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <Ellipse Width="9" Height="9"
                                     Fill="#FF4444"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Close"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

        <!-- Fullscreen launch cover: hides Steam/desktop while a game starts -->
        <Grid x:Name="LaunchCover" IsVisible="False">
            <Border Background="Black"/>
        </Grid>

        <!-- Start animation overlay — topmost, always on top during startup -->
        <Grid x:Name="StartOverlay">
            <Border Background="Black"/>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">

                <!-- Logo row -->
                <StackPanel x:Name="StartLogoGroup"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="18"
                            Opacity="0">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Rectangle Width="5" Height="20" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                        <Rectangle Width="5" Height="26" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                        <Rectangle Width="5" Height="32" Fill="{DynamicResource AccentBrush}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="StartTitleText"
                               Text="NOVA BLACKLINE"
                               FontSize="52"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Tagline -->
                <TextBlock x:Name="StartTagline"
                           Text="YOUR GAMES. YOUR WAY."
                           FontSize="13"
                           Foreground="White"
                           Opacity="0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
